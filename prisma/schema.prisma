generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  RECEPTION
  TECHNICIAN
  SALES
  WAREHOUSE
  FINANCE
  AUDITOR
}

enum RepairStatus {
  RECEIVED
  PENDING_DIAGNOSIS
  DIAGNOSING
  WAITING_ESTIMATE
  ESTIMATE_SENT
  WAITING_CUSTOMER_APPROVAL
  AUTHORIZED
  NOT_AUTHORIZED
  WAITING_PART
  PART_AVAILABLE
  REPAIRING
  TESTING
  COMPLETED
  NOT_VIABLE
  PAYMENT_PENDING
  READY_FOR_DELIVERY
  DELIVERED
  WARRANTY
  CANCELLED
  ABANDONED
}

enum EstimateStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum MessageSenderType {
  EMPLOYEE
  CUSTOMER
  SYSTEM
}

enum InventoryMovementType {
  INITIAL
  PURCHASE
  SALE
  REPAIR_USE
  ADJUSTMENT
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD_TERMINAL
  DIGITAL
}

model Branch {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  address     String?
  phone       String?
  active      Boolean       @default(true)
  users       User[]
  repairOrders RepairOrder[]
  products    Product[]
  sales       Sale[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  passwordHash   String
  role           Role
  active         Boolean       @default(true)
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  sessions       Session[]
  receivedOrders RepairOrder[] @relation("ReceivedBy")
  assignedOrders RepairOrder[] @relation("Technician")
  repairUpdates  RepairUpdate[]
  messages       Message[]
  sales          Sale[]
  auditLogs      AuditLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model Customer {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  phone           String
  alternatePhone  String?
  email           String?
  address         String?
  city            String?
  preferredContact String        @default("WHATSAPP")
  privacyAccepted Boolean        @default(false)
  privacyVersion  String?
  active          Boolean        @default(true)
  devices         Device[]
  repairOrders    RepairOrder[]
  sales           Sale[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([phone])
  @@index([email])
}

model Device {
  id           String        @id @default(cuid())
  customerId   String
  customer     Customer      @relation(fields: [customerId], references: [id])
  brand        String
  model        String
  color        String?
  serialNumber String?
  imei         String?
  capacity     String?
  repairOrders RepairOrder[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([customerId])
  @@index([serialNumber])
  @@index([imei])
}

model RepairOrder {
  id                 String          @id @default(cuid())
  publicFolio        String          @unique
  branchId           String
  branch             Branch          @relation(fields: [branchId], references: [id])
  customerId         String
  customer           Customer        @relation(fields: [customerId], references: [id])
  deviceId           String
  device             Device          @relation(fields: [deviceId], references: [id])
  receivedById       String
  receivedBy         User            @relation("ReceivedBy", fields: [receivedById], references: [id])
  technicianId       String?
  technician         User?           @relation("Technician", fields: [technicianId], references: [id])
  status             RepairStatus    @default(RECEIVED)
  issue              String
  physicalCondition  String?
  accessories        String?
  diagnosis          String?
  initialEstimate    Decimal         @db.Decimal(12, 2)
  deposit            Decimal         @default(0) @db.Decimal(12, 2)
  total              Decimal         @default(0) @db.Decimal(12, 2)
  promisedAt         DateTime?
  priority           Int             @default(2)
  accessCodeHash     String
  accessCodeLookup   String          @unique
  accessCodeLast4    String
  accessCodeRevokedAt DateTime?
  deliveredAt        DateTime?
  updates            RepairUpdate[]
  estimates          Estimate[]
  messages           Message[]
  clientSessions     ClientSession[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([customerId, status])
  @@index([technicianId, status])
  @@index([branchId, createdAt])
}

model RepairUpdate {
  id            String       @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  previousStatus RepairStatus?
  newStatus     RepairStatus
  comment       String
  sequence      Int
  visibleToCustomer Boolean  @default(true)
  createdAt     DateTime     @default(now())

  @@unique([repairOrderId, sequence])
  @@index([repairOrderId, createdAt])
}

model Estimate {
  id            String         @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder    @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  version       Int
  title         String
  reason        String
  partsAmount   Decimal        @default(0) @db.Decimal(12, 2)
  laborAmount   Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal        @db.Decimal(12, 2)
  status        EstimateStatus @default(PENDING)
  customerDecisionAt DateTime?
  customerDecisionIp String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([repairOrderId, version])
  @@index([repairOrderId, status])
}

model Message {
  id            String            @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder       @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  senderType    MessageSenderType
  senderUserId  String?
  senderUser    User?             @relation(fields: [senderUserId], references: [id])
  body          String
  visibleToCustomer Boolean       @default(true)
  createdAt     DateTime          @default(now())
  editedAt      DateTime?

  @@index([repairOrderId, createdAt])
}

model ClientSession {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  lastSeenAt    DateTime    @default(now())

  @@index([repairOrderId, expiresAt])
}

model Product {
  id          String        @id @default(cuid())
  branchId    String
  branch      Branch        @relation(fields: [branchId], references: [id])
  sku         String        @unique
  barcode     String?       @unique
  name        String
  category    String
  brand       String?
  compatibleModels String?
  cost        Decimal       @db.Decimal(12, 2)
  price       Decimal       @db.Decimal(12, 2)
  stock       Int           @default(0)
  minimumStock Int          @default(1)
  active      Boolean       @default(true)
  movements   InventoryMovement[]
  saleItems   SaleItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([branchId, active])
  @@index([category])
}

model InventoryMovement {
  id          String                @id @default(cuid())
  productId   String
  product     Product               @relation(fields: [productId], references: [id])
  type        InventoryMovementType
  quantity    Int
  previousStock Int
  newStock    Int
  reference   String?
  notes       String?
  createdAt   DateTime              @default(now())

  @@index([productId, createdAt])
}

model Sale {
  id          String      @id @default(cuid())
  folio       String      @unique
  idempotencyKey String   @unique
  branchId    String
  branch      Branch      @relation(fields: [branchId], references: [id])
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  subtotal    Decimal     @db.Decimal(12, 2)
  tax         Decimal     @default(0) @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  items       SaleItem[]
  payments    Payment[]
  createdAt   DateTime    @default(now())

  @@index([branchId, createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  description String
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
}

model Payment {
  id        String        @id @default(cuid())
  saleId    String
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  createdAt DateTime      @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  result      String   @default("SUCCESS")
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}


model AccessAttempt {
  id           String   @id @default(cuid())
  key          String   @unique
  attempts     Int      @default(0)
  blockedUntil DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}
